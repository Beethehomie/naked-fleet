# ============================================================
# RENTAL OS — ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Server ────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Database (Railway PostgreSQL) ─────────────────────────────
# Copy from Railway → your PostgreSQL service → Variables
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public

# ── Authentication ────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_character_random_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Email / SMTP ──────────────────────────────────────────────
# Mailgun (recommended), SendGrid, or any SMTP provider
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@mg.yourdomain.com
SMTP_PASS=your_mailgun_smtp_password

EMAIL_FROM_NAME=RentalOS
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

# Set to 'false' during development to prevent sending real emails
NOTIFICATIONS_ENABLED=true

# ── Automation ────────────────────────────────────────────────
# Comma-separated addresses that receive all system alert digests
ALERT_RECIPIENTS=ops@yourcompany.com,admin@yourcompany.com

# Days before expiry that a compliance item is flagged as EXPIRING_SOON
COMPLIANCE_THRESHOLD_DAYS=30

# Days after booking completion before chasing an unresolved deposit
DEPOSIT_CHASE_DAYS=7

# ── File Storage (optional — for document uploads) ────────────
# Supports any S3-compatible provider (AWS S3, Cloudflare R2, MinIO)
STORAGE_BUCKET=rental-os-documents
STORAGE_REGION=af-south-1
STORAGE_ACCESS_KEY=your_access_key
STORAGE_SECRET_KEY=your_secret_key
STORAGE_BASE_URL=https://your-bucket.s3.af-south-1.amazonaws.com

# ── SMS (optional — future Twilio integration) ────────────────
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_FROM_NUMBER=+27XXXXXXXXXX
