{
  "compilerOptions": {
    "target":           "ES2020",
    "module":           "commonjs",
    "lib":              ["ES2020"],
    "outDir":           "./dist",
    "rootDir":          "./src",
    "strict":           true,
    "esModuleInterop":  true,
    "skipLibCheck":     true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration":      false,
    "removeComments":   true,
    "sourceMap":        false,
    "noUnusedLocals":   false,
    "noUnusedParameters": false,
    "noImplicitReturns": false,
    "noFallthroughCasesInSwitch": true,
    "moduleResolution": "node",
    "baseUrl":          ".",
    "paths": {
      "@rental-os/types": ["../../packages/types/src"],
      "@rental-os/utils": ["../../packages/utils/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts"]
}
